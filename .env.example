# ─── Backend ───────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/neondb?sslmode=require

# Redis (Upstash)
REDIS_URL=redis://default:password@usw1-proud-ape-12345.upstash.io:6379

# Cloudflare R2
R2_ENDPOINT=https://accountid.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=youtube-download-suit
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev
R2_SIGNED_URL_EXPIRY=600

# JWT
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_EXPIRY_SECONDS=86400
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=secure-password-here

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Worker
WORKER_API_KEY=shared-secret-between-api-and-worker

# ─── Worker ────────────────────────────────────────────────
WORKER_ID=worker-1
WORKER_CONCURRENCY=3
TEMP_DOWNLOAD_DIR=/tmp/yds-downloads

# Apify (fallback metadata provider when yt-dlp fails)
APIFY_TOKEN=
APIFY_ACTOR_ID=
METADATA_CACHE_TTL_SECONDS=86400

# yt-dlp authentication (helps avoid HTTP 403 errors)
# Path to a Netscape-format cookies file (exported from browser extension)
YT_COOKIES_FILE=
# Extract cookies from a browser (e.g. "chrome", "firefox", "brave")
YT_COOKIES_FROM_BROWSER=

# ─── Frontend ──────────────────────────────────────────────
VITE_API_URL=http://localhost:4000/api
VITE_SITE_URL=http://localhost:5173
